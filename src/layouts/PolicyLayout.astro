---
/**
 * PolicyLayout.astro
 * Shared layout for all Audius Song of the Day policy/legal pages.
 * Extends BaseLayout with a consistent policy header (breadcrumb, title,
 * last-updated stamp) and the shared policy prose styles.
 *
 * Props:
 *   title        – page title (also used in <title> tag)
 *   description? – meta description
 *   lastUpdated? – human-readable date string shown under the heading
 */

import BaseLayout from './BaseLayout.astro';

interface Props {
	title: string;
	description?: string;
	lastUpdated?: string;
}

const {
	title,
	description,
	lastUpdated = 'June 2nd, 2026 at 23:08 UTC',
} = Astro.props;
---

<BaseLayout
	title={`${title} | Audius Song of the Day`}
	description={description}
	navLinks={[
		{ label: 'Home', href: '/' },
		{ label: 'Portfolio', href: '/portfolio' },
		{ label: 'Audius Song of the Day', href: '/audius-sotd' },
	]}
	showSponsor={false}
>
	<div class="policy-header">
		<!-- Breadcrumb -->
		<nav class="policy-breadcrumb" aria-label="Breadcrumb">
			<a href="/audius-sotd">Audius Song of the Day</a>
			<span aria-hidden="true"> / </span>
			<span aria-current="page">{title}</span>
		</nav>

		<h1>{title}</h1>

		{
			lastUpdated && (
				<p class="policy-updated">Last updated: {lastUpdated}</p>
			)
		}
	</div>

	<!-- Page-specific content -->
	<div class="policy-body">
		<slot />
	</div>
</BaseLayout>

<style>
	.policy-header {
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-border);
	}

	.policy-breadcrumb {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		margin-bottom: 1rem;
		display: flex;
		align-items: center;
		gap: 0.25rem;
		flex-wrap: wrap;
	}

	.policy-breadcrumb a {
		color: var(--color-accent);
	}

	.policy-updated {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		margin: 0.5rem 0 0;
	}

	/* ── Policy body prose ──────────────────────────────────────────────────── */
	.policy-body :global(h2) {
		font-size: 1rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--color-text-muted);
		margin: 2rem 0 0.75rem;
		border-top: 1px solid var(--color-border);
		padding-top: 1.5rem;
	}

	/* Sub-headings (h3) appear on privacy page */
	.policy-body :global(h3) {
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--color-text);
		margin: 1.25rem 0 0.5rem;
	}

	.policy-body :global(p) {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		margin-bottom: 0.9rem;
		line-height: 1.75;
	}

	.policy-body :global(ul:not(.quick-links)),
	.policy-body :global(ol) {
		padding-left: 1.5rem;
		margin-bottom: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.policy-body :global(li) {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		line-height: 1.65;
	}

	/* Contact email links */
	.policy-body :global(a:not(.quick-links__item, .btn)) {
		color: var(--color-accent);
		word-break: break-all;
	}

	.policy-body :global(a:not(.quick-links__item, .btn):hover) {
		color: var(--color-accent-hover);
	}

	/* Install buttons / CTAs */
	.policy-body :global(.btn-row) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin: 1rem 0;
	}

	.policy-body :global(.btn) {
		display: inline-flex;
		flex-direction: column;
		font-size: 0.875rem;
		font-weight: 600;
		padding: 0.6em 1.1em;
		border-radius: var(--radius);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		color: var(--color-text);
		transition:
			border-color 0.15s,
			color 0.15s;
		text-decoration: none;
		max-width: 340px;
	}

	.policy-body :global(.btn:hover) {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	.policy-body :global(.btn--primary) {
		background: var(--color-accent);
		border-color: var(--color-accent);
		color: #fff;
	}

	.policy-body :global(.btn--primary:hover) {
		opacity: 0.85;
		color: #fff;
	}

	.policy-body :global(.btn-label) {
		font-size: 0.75rem;
		font-weight: 400;
		color: var(--color-text-muted);
		margin-top: 0.15rem;
	}

	.policy-body :global(.btn--primary .btn-label) {
		color: rgba(255, 255, 255, 0.7);
	}

	/* Warning callout (used on installation page) */
	.policy-body :global(.callout) {
		background: color-mix(in srgb, #f59e0b 8%, var(--color-surface));
		border: 1px solid color-mix(in srgb, #f59e0b 40%, transparent);
		border-radius: var(--radius);
		padding: 0.85rem 1rem;
		font-size: 0.85rem;
		color: var(--color-text-muted);
		margin: 0.5rem 0 1rem;
	}

	.policy-body :global(.callout strong) {
		color: #fbbf24;
	}

	/* Code / command references */
	.policy-body :global(code) {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 4px;
		padding: 0.1em 0.45em;
		color: var(--color-accent);
	}

	.policy-body :global(.btn--default-install) {
		max-width: 100%;
	}
</style>
