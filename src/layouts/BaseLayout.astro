---
/**
 * BaseLayout.astro
 * The root layout. Every page should wrap its content in this component.
 *
 * Props:
 *   title        – <title> tag content (appended with " | tobezdev.com")
 *   description? – meta description (defaults to a generic fallback)
 *   navLinks?    – override the default navbar links (passed straight to <Navbar>)
 *   showSponsor? – show GitHub Sponsors badge in footer (default: true)
 */

import Navbar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface NavLink {
	label: string;
	href: string;
}

interface Props {
	title: string;
	description?: string;
	navLinks?: NavLink[];
	showSponsor?: boolean;
}

const {
	title,
	description = 'tobezdev – developer, community manager, and musician.',
	navLinks,
	showSponsor = true,
} = Astro.props;

const fullTitle = title === 'Home' ? 'tobezdev.com' : `${title} | tobezdev.com`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />

		<!-- Open Graph -->
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />

		<link rel="icon" type="image/x-icon" href="/favicon.ico" />

		<!-- Fonts via Google Fonts (swap avoids FOIT) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<script is:inline>
			const theme =
				localStorage.getItem('theme') ??
				(window.matchMedia('(prefers-color-scheme: dark)').matches
					? 'dark'
					: 'light');
			document.documentElement.classList.toggle(
				'light',
				theme === 'light'
			);
		</script>

		<title>{fullTitle}</title>
	</head>
	<body>
		<Navbar links={navLinks} />

		<main id="content">
			<slot />
		</main>

		<Footer showSponsor={showSponsor} />
	</body>
</html>
