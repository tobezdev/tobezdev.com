---
/**
 * Footer.astro
 * Site-wide footer. Displays copyright, attribution, and an optional
 * GitHub Sponsors button.
 *
 * Props:
 *   showSponsor?: boolean  – whether to render the GitHub Sponsors badge (default: true)
 */

interface Props {
	showSponsor?: boolean;
}

const { showSponsor = true } = Astro.props;

const year = new Date().getFullYear();
const copyrightStart = 2023;
const copyrightRange =
	year > copyrightStart
		? `${copyrightStart}–${year}`
		: String(copyrightStart);
---

<footer class="footer">
	<div class="footer__inner">
		<p class="footer__copy">
			© {copyrightRange} tobezdev.com. All rights reserved.
		</p>
		<p class="footer__attr">
			Website design &amp; development by tobezdev.
		</p>

		{
			showSponsor && (
				<a
					class="footer__sponsor"
					href="https://github.com/sponsors/tobezdev"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Sponsor tobezdev on GitHub"
				>
					<img
						src="https://img.shields.io/static/v1?label=Sponsor&message=%E2%9D%A4&logo=GitHub&color=%23fe8e86"
						alt="GitHub Sponsors"
						width="116"
						height="20"
					/>
				</a>
			)
		}
	</div>
</footer>

<style>
	.footer {
		border-top: 1px solid var(--color-border);
		margin-top: auto;
	}

	.footer__inner {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: 2rem var(--content-padding);
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.35rem;
	}

	.footer__copy,
	.footer__attr {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		margin: 0;
	}

	.footer__sponsor {
		margin-top: 0.75rem;
		display: inline-flex;
	}

	.footer__sponsor:hover {
		opacity: 0.8;
	}
</style>
