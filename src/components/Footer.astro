---
/**
 * Footer.astro
 * Site-wide footer. Displays copyright, attribution, and an optional
 * GitHub Sponsors button.
 *
 * Props:
 *   showSponsor?: boolean  – whether to render the GitHub Sponsors badge (default: true)
 */

interface Props {
	showSponsor?: boolean;
}

const { showSponsor = true } = Astro.props;

const year = new Date().getFullYear();
const copyrightStart = 2023;
const copyrightRange =
	year > copyrightStart
		? `${copyrightStart}–${year}`
		: String(copyrightStart);
---

<footer class="footer">
	<div class="footer__inner">
		<div class="footer__left">
			<p class="footer__copy">
				© {copyrightRange} tobezdev.com. All rights reserved.
			</p>
			<p class="footer__attr">
				Website design &amp; development by tobezdev.
			</p>
		</div>
		<div class="footer__right">
		{
			showSponsor && (
				<iframe src="https://github.com/sponsors/tobezdev/button" title="Sponsor tobezdev" height="32" width="114" style="border: 0; border-radius: 6px;"></iframe>
			)
		}
		</div>
	</div>
</footer>

<style>
	.footer {
		border-top: 1px solid var(--color-border);
		margin-top: auto;
	}

	.footer__inner {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: 2rem var(--content-padding);
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
	}


	.footer__copy,
	.footer__attr {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		margin: 0;
	}

	.footer__sponsor {
		margin-top: 0.75rem;
		display: inline-flex;
	}

	.footer__sponsor:hover {
		opacity: 0.8;
	}
</style>