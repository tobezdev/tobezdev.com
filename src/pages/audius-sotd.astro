---
import BaseLayout from '../layouts/BaseLayout.astro';

const credits = [
	{
		name: 'FckUwU',
		url: 'https://audius.co/fckuwumusic',
	},
	{
		name: 'The Audius Team',
		url: 'https://discord.com/audius',
	},
	{
		name: 'Open-Source Contributors',
		url: 'https://github.com/tobezdev/audius-song-of-the-day/graphs/contributors',
	},
];

const quickLinks = [
	{ label: 'Terms of Service', href: '/audius-sotd/terms/' },
	{ label: 'Privacy Policy', href: '/audius-sotd/privacy/' },
	{ label: 'Cookie Policy', href: '/audius-sotd/cookies/' },
	{
		label: 'Data Processing Agreement',
		href: '/audius-sotd/data-processing/',
	},
	{ label: 'Security Policy', href: '/audius-sotd/security/' },
	{
		label: 'Installation & Setup Guide',
		href: '/audius-sotd/installation-and-setup/',
	},
	{
		label: 'Contributing Guide',
		href: '/audius-sotd/contributing',
	}
];
---

<BaseLayout
	title="Audius Song of the Day"
	description="A configurable Discord bot that sends daily songs from the Audius platform, helping you discover new music."
	navLinks={[
		{ label: 'Home', href: '/' },
		{ label: 'Portfolio', href: '/portfolio' },
	]}
>
	<h1>Audius Song of the Day</h1>

	<!-- ── Credits ────────────────────────────────────────────────────────── -->
	<h2>Credits</h2>
	<p>Thank you to everyone who has contributed, you are awesome! 💜</p>

	<ul class="credits-list" role="list">
		{
			credits.map(({ name, url }) => (
				<li>
					<a
						href={url}
						target="_blank"
						rel="noopener noreferrer"
						class="credits-list__item"
					>
						{name}
					</a>
				</li>
			))
		}
	</ul>

	<!-- ── Quick Links ────────────────────────────────────────────────────── -->
	<h2>Quick Links</h2>

	<ul class="quick-links" role="list">
		{
			quickLinks.map(({ label, href }) => (
				<li>
					<a href={href} class="quick-links__item">
						{label}
					</a>
				</li>
			))
		}
	</ul>
</BaseLayout>

<style>
	.credits-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-bottom: 0.5rem;
	}

	.credits-list__item {
		display: inline-flex;
		font-weight: 600;
		font-size: 0.95rem;
	}

	.quick-links {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.quick-links__item {
		font-size: 0.875rem;
		color: var(--color-text-muted);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		padding: 0.4em 0.9em;
		border-radius: var(--radius);
		transition:
			color 0.15s,
			border-color 0.15s;
	}

	.quick-links__item:hover {
		color: var(--color-text);
		border-color: var(--color-accent);
	}
</style>
