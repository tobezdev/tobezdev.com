---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubpagesQuickLinks from '../components/SubpagesQuickLinks.astro';

const credits = [
	{
		name: 'FckUwU',
		url: 'https://audius.co/fckuwumusic',
	},
	{
		name: 'The Audius Team',
		url: 'https://discord.com/audius',
	},
	{
		name: 'Open-Source Contributors',
		url: 'https://github.com/tobezdev/audius-song-of-the-day/graphs/contributors',
	},
];
---

<BaseLayout
	title="Audius Song of the Day"
	description="A configurable Discord bot that sends daily songs from the Audius platform, helping you discover new music."
	navLinks={[
		{ label: 'Home', href: '/' },
		{ label: 'Portfolio', href: '/portfolio' },
		{ label: 'Audius Song of the Day', href: '/audius-sotd' },
	]}
>
	<h1>Audius Song of the Day</h1>

	<!-- ── Credits ────────────────────────────────────────────────────────── -->
	<h2>Credits</h2>
	<p>Thank you to everyone who has contributed, you are awesome! 💜</p>

	<ul class="credits-list" role="list">
		{
			credits.map(({ name, url }) => (
				<li>
					<a
						href={url}
						target="_blank"
						rel="noopener noreferrer"
						class="credits-list__item"
					>
						{name}
					</a>
				</li>
			))
		}
	</ul>

	<!-- ── Quick Links ────────────────────────────────────────────────────── -->
	<SubpagesQuickLinks />
</BaseLayout>

<style>
	.credits-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-bottom: 0.5rem;
	}

	.credits-list__item {
		display: inline-flex;
		font-weight: 600;
		font-size: 0.95rem;
	}
</style>
