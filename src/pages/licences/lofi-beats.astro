---
import BaseLayout from '../../layouts/BaseLayout.astro';

const quickLinks = [
	{ label: 'Summary Of Terms', href: '#summary-of-terms' },
	{ label: 'Additional Notices', href: '#additional-notices' },
	{ label: 'Recommended Attribution', href: '#recommended-attribution' },
];
---

<BaseLayout
	title="Lo-fi Background Music Licence"
	description="Licence terms and attribution details for the track use page."
	navLinks={[
		{ label: 'Home', href: '/' },
		{ label: 'Portfolio', href: '/portfolio' },
	]}
>
	<h1>Lo-fi Background Music Licence</h1>
	<p>
		tobezdev / remixify's <a
			href="https://remixify.com/lo-fi-background-beats"
			target="_blank"
			rel="noopener noreferrer">Lo-Fi Background Beats</a
		> is licensed under the <a
			href="https://creativecommons.org/licenses/by-nd/4.0/"
			target="_blank"
			rel="noopener noreferrer"
			>Creative Commons Attribution-NoDerivatives 4.0 International
			License</a
		>. Provided below is a short summary of what this license permits,
		however, you should not treat this as legal advice. For full terms, read
		the full license text: <a
			href="https://creativecommons.org/licenses/by-nd/4.0/legalcode.txt"
			target="_blank"
			rel="noopener noreferrer"
			>https://creativecommons.org/licenses/by-nd/4.0/legalcode.txt</a
		>.
	</p>
	<h2>Quick Links</h2>
	<ul class="quick-links" role="list">
		{
			quickLinks.map(({ label, href }) => (
				<li>
					<a href={href} class="quick-links__item">
						{label}
					</a>
				</li>
			))
		}
	</ul>
	<h2 id="summary-of-terms">Summary of Terms</h2>
	<ul>
		<li>
			You are free to share (copy and redistribute) the material in any
			medium or format for any purpose, even commercially.
		</li>
		<li>
			You must give appropriate credit, provide a link to the license, and
			indicate if changes were made. You may do so in any reasonable
			manner, but not in any way that suggests the licensor endorses you
			or your use.
		</li>
		<li>
			If you remix, transform, or build upon the material, you may not
			distribute the modified material.
		</li>
	</ul>
	<h2 id="additional-notices">Additional Notices</h2>
	<ul>
		<li>
			You do not have to comply with the license for elements of the
			material in the public domain or where your use is permitted by an
			applicable exception or limitation.
		</li>
		<li>
			No warranties are given. The license may not give you all of the
			permissions necessary for your intended use. For example, other
			rights such as publicity, privacy, or moral rights may limit how you
			use the material.
		</li>
		<li>
			You may not apply legal terms or technological measures that legally
			restrict others from doing anything the license permits, or grant
			access to material that the license does not permit to be accessed.
		</li>
	</ul>
	<h2 id="recommended-attribution">Recommended Attribution</h2>
	<p>
		When using this material, it is recommended to include the following
		attribution. You may, however, choose to attribute in a different way,
		as long as it is reasonable and complies with the license terms.
		<br />
		<div class="attribution-card">
			<p class="attributiion-text">
				Background Music:<br />
				Lo-Fi Background Beats by tobezdev / remixify on Audius<br />
				https://audius.co/remixify/album/lo-fi-background-beats<br />
				Licensed under CC BY-ND 4.0
			</p>
		</div>
	</p>
</BaseLayout>

<style>
	.availability {
		margin-bottom: 0.5rem;
		font-size: 0.875rem;
	}

	/* ── Experience cards ──────────────────────────────────────────────────── */
	.exp-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.exp-card {
		padding: 1.25rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.exp-card__header {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.exp-card__logo {
		width: 40px;
		height: 40px;
		object-fit: contain;
		border-radius: var(--radius);
		flex-shrink: 0;
		background: #fff;
		padding: 2px;
	}

	.exp-card__meta {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.exp-card__org {
		font-weight: 700;
		font-size: 1rem;
		color: var(--color-text);
	}

	.exp-card__org:hover {
		color: var(--color-accent);
	}

	.exp-card__role {
		font-size: 0.85rem;
		color: var(--color-text-muted);
	}

	.exp-card__period {
		font-size: 0.78rem;
		color: var(--color-text-muted);
		white-space: nowrap;
		margin-left: auto;
		padding-top: 2px;
	}

	.exp-card__desc {
		font-size: 0.875rem;
		margin: 0;
	}

	.exp-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	/* ── Contact ───────────────────────────────────────────────────────────── */
	.contact-list {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.contact-list__item {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-size: 0.875rem;
		color: var(--color-text-muted);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		padding: 0.4em 0.9em;
		border-radius: 999px;
		transition:
			color 0.15s,
			border-color 0.15s;
	}

	.contact-list__item:hover {
		color: var(--color-text);
		border-color: var(--color-accent);
	}

	.contact-list__item img {
		width: 16px;
		height: 16px;
		object-fit: contain;
	}

	/* ── Notice ────────────────────────────────────────────────────────────── */
	.asset-notice {
		margin-top: 2rem;
		font-size: 0.78rem;
		color: var(--color-text-muted);
		border-left: 2px solid var(--color-border);
		padding-left: 0.85rem;
	}

	/* ── Quick Links ───────────────────────────────────────────────────────── */
	.quick-links {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.quick-links__item {
		font-size: 0.875rem;
		color: var(--color-text-muted);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		padding: 0.4em 0.9em;
		border-radius: var(--radius);
		transition:
			color 0.15s,
			border-color 0.15s;
	}

	.quick-links__item:hover {
		color: var(--color-text);
		border-color: var(--color-accent);
	}

	/* ── Attribution Text  ───────────────────────────────────────────────────────── */
	div .attribution-card {
		margin-top: 1rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		padding: 0.75rem;
	}

	div.attribution-card p.attributiion-text {
		font-size: 0.875rem;
		color: var(--color-text);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		padding: 0.4em 0.9em;
		border-radius: var(--radius);
	}
</style>
