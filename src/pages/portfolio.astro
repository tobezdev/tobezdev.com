---
import BaseLayout from '../layouts/BaseLayout.astro';

/**
 * Each experience entry. Update this array whenever your CV changes —
 * no need to touch the markup below.
 */
const experience = [
	{
		org: 'Audius',
		orgUrl: 'https://audius.co/',
		logo: 'https://brand.audius.co/images/LogoGlyph-Color_10242x-p-500.webp',
		logoAlt: 'Audius Logo',
		role: 'Community Manager & Artist Relations Assistant',
		period: 'Jul 2025 - Mar 2026',
		description:
			'Community management, user support, and artist engagement for a decentralised music platform. Also contributed to platform development including the website, a custom $AUDIO Discord bot, and blockchain tooling.',
		tags: ['Community', 'Web3', 'Blockchain'],
	},
	{
		org: 'South Western Railway',
		orgUrl: 'https://southwesternrailway.com/',
		logo: 'https://cdn.prgloo.com/media/c64e222444ba4a3cbcb7806e70e261f2.jpg?width=640&height=960',
		logoAlt: 'South Western Railway Logo',
		role: 'Gateline & Platform Operations Assistant',
		period: 'Jun 2025 - Sept 2025',
		description:
			'Front-line passenger assistance — ticketing, travel advice, and station operations. Ensured smooth service delivery and resolved customer issues in a fast-paced environment.',
		tags: ['Customer Service', 'Operations', 'Travel'],
	},
	{
		org: 'Curity',
		orgUrl: 'https://curity.io/',
		logo: 'https://cdn.brandfetch.io/idhiyE1CFN/w/400/h/400/theme/dark/icon.jpeg?c=1bxid64Mup7aczewSAYMX&t=1779811618296',
		logoAlt: 'Curity Logo',
		role: 'Security Development Partner',
		period: 'Apr 2024 - Jun 2025',
		description:
			'Performed security vulnerability analysis and helped deliver real-time threat intelligence feeds to enterprise clients.',
		tags: ['Security', 'Vulnerability Analysis', 'Python'],
	},
];
---

<BaseLayout
	title="Portfolio"
	description="Experience, contact details, and recent work from tobezdev."
	navLinks={[
		{ label: 'Home', href: '/' },
		{ label: 'Portfolio', href: '/portfolio' },
	]}
>
	<h1>Hey, I'm tobezdev.</h1>

	<p class="availability">
		<a href="#contact">Available for Commissions — contact for more info!</a
		>
	</p>

	<!-- ── Experience ─────────────────────────────────────────────────────── -->
	<h2 id="experience">Experience</h2>

	<ul class="exp-list" role="list">
		{
			experience.map(
				({
					org,
					orgUrl,
					logo,
					logoAlt,
					role,
					period,
					description,
					tags,
				}) => (
					<li class="exp-card">
						<div class="exp-card__header">
							<img
								src={logo}
								alt={logoAlt}
								class="exp-card__logo"
								width="40"
								height="40"
							/>
							<div class="exp-card__meta">
								<a
									href={orgUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="exp-card__org"
								>
									{org}
								</a>
								<span class="exp-card__role">{role}</span>
							</div>
							<span class="exp-card__period">{period}</span>
						</div>
						<p class="exp-card__desc">{description}</p>
						<div class="exp-card__tags" aria-label="Skills">
							{tags.map((tag) => (
								<span class="tag">{tag}</span>
							))}
						</div>
					</li>
				)
			)
		}
	</ul>

	<!-- ── Contact ────────────────────────────────────────────────────────── -->
	<h2 id="contact">Let's Connect</h2>

	<ul class="contact-list" role="list">
		<li>
			<a href="mailto:toby@tobezdev.com" class="contact-list__item">
				✉ toby@tobezdev.com
			</a>
		</li>
		<li>
			<a
				href="https://linkedin.com/in/tobezdev"
				target="_blank"
				rel="noopener noreferrer"
				class="contact-list__item"
			>
				<img
					src="https://iili.io/q5eoXgR.md.png"
					alt=""
					width="16"
					height="16"
					aria-hidden="true"
				/>
				in/tobezdev
			</a>
		</li>
		<li>
			<a
				href="https://discordapp.com/users/969254887621820526"
				target="_blank"
				rel="noopener noreferrer"
				class="contact-list__item"
			>
				<img
					src="https://cdn.prod.website-files.com/6257adef93867e50d84d30e2/66e3d7f4ef6498ac018f2c55_Symbol.svg"
					alt=""
					width="16"
					height="16"
					aria-hidden="true"
				/>
				@tobezdev
			</a>
		</li>
	</ul>

	<p class="asset-notice">
		Some assets on this page are copyright protected and are used with
		explicit written permission from the copyright owner(s) — please consult
		the asset copyright owner for permission before using any assets on this
		page.
	</p>
</BaseLayout>

<style>
	.availability {
		margin-bottom: 0.5rem;
		font-size: 0.875rem;
	}

	/* ── Experience cards ──────────────────────────────────────────────────── */
	.exp-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.exp-card {
		padding: 1.25rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.exp-card__header {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.exp-card__logo {
		width: 40px;
		height: 40px;
		object-fit: contain;
		border-radius: var(--radius);
		flex-shrink: 0;
		background: #fff;
		padding: 2px;
	}

	.exp-card__meta {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.exp-card__org {
		font-weight: 700;
		font-size: 1rem;
		color: var(--color-text);
	}

	.exp-card__org:hover {
		color: var(--color-accent);
	}

	.exp-card__role {
		font-size: 0.85rem;
		color: var(--color-text-muted);
	}

	.exp-card__period {
		font-size: 0.78rem;
		color: var(--color-text-muted);
		white-space: nowrap;
		margin-left: auto;
		padding-top: 2px;
	}

	.exp-card__desc {
		font-size: 0.875rem;
		margin: 0;
	}

	.exp-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	/* ── Contact ───────────────────────────────────────────────────────────── */
	.contact-list {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.contact-list__item {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-size: 0.875rem;
		color: var(--color-text-muted);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		padding: 0.4em 0.9em;
		border-radius: 999px;
		transition:
			color 0.15s,
			border-color 0.15s;
	}

	.contact-list__item:hover {
		color: var(--color-text);
		border-color: var(--color-accent);
	}

	.contact-list__item img {
		width: 16px;
		height: 16px;
		object-fit: contain;
	}

	/* ── Notice ────────────────────────────────────────────────────────────── */
	.asset-notice {
		margin-top: 2rem;
		font-size: 0.78rem;
		color: var(--color-text-muted);
		border-left: 2px solid var(--color-border);
		padding-left: 0.85rem;
	}
</style>
